{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main Rewind window. Grants the permissions needed by the plugins wired in src-tauri/src/lib.rs.",
  "windows": ["main", "overlay"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-set-focus",
    "core:window:allow-show",
    "core:window:allow-unminimize",
    "core:webview:default",
    "core:event:default",
    "core:tray:default",
    "core:menu:default",
    "core:app:default",
    "notification:default",
    "autostart:default",
    "global-shortcut:default",
    "positioner:default",
    "store:default",
    "window-state:default"
  ]
}
